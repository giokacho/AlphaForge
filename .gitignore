# =============================================================================
# AlphaForge — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment / secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
**/.env
*.env

# Explicit per-bot .env paths (belt-and-suspenders)
macro-bot/.env
news-bot/.env
debate-bot/.env
technicals-bot/.env
dashboard/backend/.env

# ---------------------------------------------------------------------------
# Python artefacts
# ---------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/
.env/       # catches any folder accidentally named .env

# ---------------------------------------------------------------------------
# Bot outputs & runtime artefacts (never commit)
# ---------------------------------------------------------------------------
**/outputs/
logs/
reports/
*.db
shared/combined_context.json
shared/final_verdict.json

# ---------------------------------------------------------------------------
# OS / editor noise
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
